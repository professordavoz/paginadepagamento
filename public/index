<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academia da Voz — Checkout</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f0f1a;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .container {
      background: #1a1a2e;
      border-radius: 16px;
      padding: 40px 32px;
      max-width: 420px;
      width: 100%;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }

    h1 {
      font-size: 22px;
      margin-bottom: 6px;
      color: #fff;
    }

    .subtitulo {
      font-size: 14px;
      color: #aaa;
      margin-bottom: 28px;
    }

    .preco {
      font-size: 36px;
      font-weight: 700;
      color: #00d4aa;
      margin-bottom: 28px;
    }

    .preco span {
      font-size: 16px;
      color: #aaa;
      font-weight: 400;
    }

    label {
      display: block;
      font-size: 13px;
      color: #aaa;
      margin-bottom: 6px;
    }

    input {
      width: 100%;
      padding: 12px 14px;
      background: #0f0f1a;
      border: 1px solid #333;
      border-radius: 8px;
      color: #fff;
      font-size: 15px;
      margin-bottom: 16px;
      outline: none;
      transition: border 0.2s;
    }

    input:focus {
      border-color: #00d4aa;
    }

    input::placeholder {
      color: #555;
    }

    button {
      width: 100%;
      padding: 14px;
      background: #00d4aa;
      color: #000;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s, opacity 0.2s;
      margin-top: 4px;
    }

    button:hover { background: #00bfa0; }
    button:disabled { opacity: 0.5; cursor: not-allowed; }

    #status {
      margin-top: 20px;
      font-size: 14px;
      text-align: center;
      min-height: 20px;
    }

    .seguro {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 20px;
      font-size: 12px;
      color: #555;
    }
  </style>
</head>
<body>

<div class="container">
  <h1>Academia da Voz</h1>
  <p class="subtitulo">Acesso completo ao curso</p>

  <div class="preco">R$ 35,00 <span>/ pagamento único</span></div>

  <div id="form-container">
    <label>Nome completo</label>
    <input type="text" id="nome" placeholder="Seu nome">

    <label>E-mail</label>
    <input type="email" id="email" placeholder="seu@email.com">

    <label>CPF</label>
    <input type="text" id="cpf" placeholder="000.000.000-00" maxlength="14" oninput="mascaraCPF(this)">

    <button id="btn" onclick="processarFluxo()">
      Pagar com PIX
    </button>
  </div>

  <div id="status"></div>

  <div class="seguro">
    🔒 Pagamento 100% seguro via PIX
  </div>
</div>

<script>
  function mascaraCPF(input) {
    let v = input.value.replace(/\D/g, '').substring(0, 11);
    v = v.replace(/(\d{3})(\d)/, '$1.$2');
    v = v.replace(/(\d{3})(\d)/, '$1.$2');
    v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
    input.value = v;
  }

  let vigia = null;
  let tentativasFalha = 0;
  const MAX_FALHAS = 5;

  async function processarFluxo() {
    const statusEl = document.getElementById('status');
    const btn = document.getElementById('btn');
    const nome = document.getElementById('nome').value.trim();
    const email = document.getElementById('email').value.trim();
    const cpfLimpo = document.getElementById('cpf').value.replace(/\D/g, '');

    if (!email || !cpfLimpo) {
      statusEl.innerHTML = `<b style="color:#ffcc00">Preencha o E-mail e o CPF!</b>`;
      return;
    }

    statusEl.innerHTML = "Verificando histórico de pagamentos...";
    btn.disabled = true;

    try {
      const busca = await call('/api/checkout', {
        action: 'check_global',
        payload: { cpfCnpj: cpfLimpo }
      });

      if (JSON.stringify(busca).includes('RECEIVED') || JSON.stringify(busca).includes('CONFIRMED')) {
        redirecionarSucesso();
        return;
      }

      statusEl.innerHTML = "Identificando cadastro...";
      const cli = await call('/api/checkout', {
        action: 'create_customer',
        payload: { name: nome || email, email: email, cpfCnpj: cpfLimpo }
      });

      statusEl.innerHTML = "Gerando PIX...";
      const pag = await call('/api/checkout', {
        action: 'create_payment',
        payload: {
          customer: cli.id,
          billingType: 'PIX',
          value: 35.00,
          dueDate: new Date(Date.now() + 86400000).toISOString().split('T')[0],
          externalReference: email
        }
      });

      const qr = await call('/api/checkout', {
        action: 'pix_qrcode',
        payload: { paymentId: pag.id }
      });

      document.getElementById('form-container').style.display = 'none';
      statusEl.innerHTML = `
        <div style="background:#fff; color:#000; padding:20px; border-radius:12px; text-align:center;">
          <p style="font-weight:bold; margin-bottom:12px;">Escaneie o QR Code abaixo</p>
          <img src="data:image/png;base64,${qr.encodedImage}" style="width:100%; max-width:240px; border-radius:8px;">
          <p style="margin:12px 0 4px; font-size:12px; color:#666;">Ou copie o código PIX:</p>
          <p style="background:#f0f0f0; padding:10px; border-radius:6px; font-size:10px; word-break:break-all; cursor:pointer;"
             onclick="copiarPix('${qr.payload}')">${qr.payload}</p>
          <p style="margin-top:8px; font-size:12px; color:#999;">Toque no código para copiar</p>
          <p style="color:#0066cc; font-weight:bold; margin-top:12px;">Aguardando pagamento...</p>
          <div id="radar-asaas" style="margin-top:10px; padding:8px; background:#1a1a2e; color:#00d4aa; font-family:monospace; border-radius:6px; font-size:11px;">
            Verificando...
          </div>
        </div>`;

      iniciarVigia(pag.id);

    } catch (err) {
      statusEl.innerHTML = `<b style="color:#ff6b6b">Erro: ${err.message}</b>`;
      btn.disabled = false;
    }
  }

  function copiarPix(texto) {
    navigator.clipboard.writeText(texto).then(() => {
      alert('Código PIX copiado!');
    });
  }

  function iniciarVigia(paymentId) {
    if (vigia) clearInterval(vigia);
    tentativasFalha = 0;

    vigia = setInterval(async () => {
      try {
        const res = await call('/api/checkout', {
          action: 'check_status',
          payload: { paymentId }
        });

        const radar = document.getElementById('radar-asaas');
        const statusAtual = res.status || 'aguardando';

        if (radar) radar.innerHTML = `Status: ${statusAtual}`;

        if (statusAtual === 'RECEIVED' || statusAtual === 'CONFIRMED') {
          clearInterval(vigia);
          vigia = null;
          redirecionarSucesso();
        }

        tentativasFalha = 0;

      } catch (err) {
        tentativasFalha++;
        const radar = document.getElementById('radar-asaas');
        if (radar) radar.innerHTML = `Verificando... (tentativa ${tentativasFalha})`;

        if (tentativasFalha >= MAX_FALHAS) {
          clearInterval(vigia);
          vigia = null;
          const statusEl = document.getElementById('status');
          if (statusEl) {
            statusEl.innerHTML += `
              <p style="color:#ffcc00; font-size:12px; margin-top:10px;">
                Se você já pagou, <a href="/obrigado" style="color:#00d4aa">clique aqui</a>.
              </p>`;
          }
        }
      }
    }, 5000);
  }

  function redirecionarSucesso() {
    if (vigia) { clearInterval(vigia); vigia = null; }
    document.getElementById('status').innerHTML = `
      <h2 style="color:#00d4aa">✅ PAGAMENTO CONFIRMADO!</h2>
      <p style="margin-top:8px;">Redirecionando...</p>`;
    setTimeout(() => {
      window.location.replace("/obrigado");
    }, 2000);
  }

  async function call(url, body) {
    const r = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });

    const texto = await r.text();
    if (!texto) throw new Error("Servidor não respondeu.");

    let dados;
    try { dados = JSON.parse(texto); }
    catch (e) { throw new Error(`Resposta inválida: ${texto.substring(0, 200)}`); }

    if (dados.error) throw new Error(dados.error);
    return dados;
  }
</script>

</body>
</html>
