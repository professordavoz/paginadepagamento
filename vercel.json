{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/obrigado", "dest": "/obrigado.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
